# PostgreSQL — used by the Prisma runtime (adapter reads this).
# Local dev via docker-compose: port 5433 (5432 kept free for other projects).
DATABASE_URL="postgresql://renai:renai_dev@localhost:5433/renai?schema=public"

# Optional — if using a pooler (e.g. Supabase PgBouncer) for runtime, point
# DIRECT_URL at a non-pooled connection so migrations/DDL work correctly.
# DIRECT_URL="postgresql://user:password@localhost:5432/renai?schema=public"

# Session secret — 32+ random bytes, base64 or hex.
# Generate: openssl rand -base64 32
SESSION_SECRET="replace-me-with-a-random-secret"

# Sentry (ADR-003). Get the DSN from sentry.io → Settings → Projects → Client
# Keys. Same value for both vars; the NEXT_PUBLIC_ copy gets inlined into
# the browser bundle. Without these the Sentry SDK initialises as a no-op,
# so leaving them empty is fine for local dev.
# Use SENTRY_ENVIRONMENT to distinguish development / staging / production
# in the Sentry UI.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"
