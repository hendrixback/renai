# PostgreSQL — used by the Prisma runtime (adapter reads this).
# Local dev via docker-compose: port 5433 (5432 kept free for other projects).
DATABASE_URL="postgresql://renai:renai_dev@localhost:5433/renai?schema=public"

# Optional — if using a pooler (e.g. Supabase PgBouncer) for runtime, point
# DIRECT_URL at a non-pooled connection so migrations/DDL work correctly.
# DIRECT_URL="postgresql://user:password@localhost:5432/renai?schema=public"

# Session secret — 32+ random bytes, base64 or hex.
# Generate: openssl rand -base64 32
SESSION_SECRET="replace-me-with-a-random-secret"

# Sentry (ADR-003). Get the DSN from sentry.io → Settings → Projects → Client
# Keys. Same value for both vars; the NEXT_PUBLIC_ copy gets inlined into
# the browser bundle. Without these the Sentry SDK initialises as a no-op,
# so leaving them empty is fine for local dev.
# Use SENTRY_ENVIRONMENT to distinguish development / staging / production
# in the Sentry UI.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"

# AI assistant (Spec §19.4, ADR-011). Provider-agnostic: any
# OpenAI-compatible inference endpoint works. Leave AI_API_KEY empty to
# disable the floating assistant entirely (the widget renders null until
# both AI_API_KEY and AI_MODEL are set).
#
# Examples:
#   OpenRouter free Llama (truly free, rate-limited, OK for dev/QA):
#     AI_BASE_URL="https://openrouter.ai/api/v1"
#     AI_API_KEY="sk-or-v1-..."
#     AI_MODEL="meta-llama/llama-3.3-70b-instruct:free"
#     AI_PROVIDER="openrouter"
#
#   Groq free Llama (very fast, free tier):
#     AI_BASE_URL="https://api.groq.com/openai/v1"
#     AI_API_KEY="gsk_..."
#     AI_MODEL="llama-3.3-70b-versatile"
#     AI_PROVIDER="groq"
#
#   Anthropic (paid; matches ADR-011 once budget approved):
#     AI_BASE_URL="https://api.anthropic.com/v1/"
#     AI_API_KEY="sk-ant-..."
#     AI_MODEL="claude-haiku-4-5-20251001"
#     AI_PROVIDER="anthropic"
#
#   Local Ollama (dev only, free, no data egress):
#     AI_BASE_URL="http://localhost:11434/v1"
#     AI_API_KEY="ollama"
#     AI_MODEL="llama3.3"
#     AI_PROVIDER="ollama"
#
# AI_MAX_OUTPUT_TOKENS caps the model response (default 1024).
AI_API_KEY=""
AI_MODEL=""
AI_BASE_URL=""
AI_PROVIDER=""
AI_MAX_OUTPUT_TOKENS="1024"
