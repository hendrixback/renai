// Prisma schema — edit to model your domain. Migrations live in prisma/migrations.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Identity & Tenancy ──────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         UserRole  @default(MEMBER) // platform-level; see Membership for per-company roles
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberships               Membership[]
  createdWasteFlows         WasteFlow[]        @relation("WasteFlowCreatedBy")
  updatedWasteFlows         WasteFlow[]        @relation("WasteFlowUpdatedBy")
  invitationsSent           Invitation[]       @relation("InvitationInviter")
  invitationsAccepted       Invitation[]       @relation("InvitationAcceptee")
  createdSites              Site[]             @relation("SiteCreatedBy")
  updatedSites              Site[]             @relation("SiteUpdatedBy")
  createdFuelEntries        FuelEntry[]        @relation("FuelEntryCreatedBy")
  updatedFuelEntries        FuelEntry[]        @relation("FuelEntryUpdatedBy")
  createdElectricityEntries ElectricityEntry[] @relation("ElectricityEntryCreatedBy")
  updatedElectricityEntries ElectricityEntry[] @relation("ElectricityEntryUpdatedBy")
  createdScope3Entries      Scope3Entry[]      @relation("Scope3EntryCreatedBy")
  updatedScope3Entries      Scope3Entry[]      @relation("Scope3EntryUpdatedBy")
  uploadedDocuments         Document[]         @relation("DocumentUploadedBy")
  linkedDocuments           DocumentLink[]     @relation("DocumentLinkLinkedBy")
  activityLogs              ActivityLog[]
  importedFactorRevisions   FactorRevision[]   @relation("FactorRevisionImporter")

  @@index([role])
  @@index([lastActiveAt])
}

enum UserRole {
  ADMIN
  MEMBER
}

model Company {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  vatNumber    String?
  country      String?  @db.VarChar(2)
  baselineYear Int? // ESG baseline year for YoY comparison (CSRD/ISSB requirement)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships        Membership[]
  sites              Site[]
  wasteFlows         WasteFlow[]
  invitations        Invitation[]
  fuelEntries        FuelEntry[]
  electricityEntries ElectricityEntry[]
  scope3Entries      Scope3Entry[]
  emissionFactors    EmissionFactor[]
  documents          Document[]
  activityLogs       ActivityLog[]
  factorRevisions    FactorRevision[]
}

model Invitation {
  id               String         @id @default(cuid())
  companyId        String
  email            String
  role             MembershipRole @default(MEMBER)
  token            String         @unique
  expiresAt        DateTime
  invitedById      String
  acceptedAt       DateTime?
  acceptedByUserId String?
  revokedAt        DateTime?
  createdAt        DateTime       @default(now())

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy  User    @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy User?   @relation("InvitationAcceptee", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([email])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  companyId String
  role      MembershipRole @default(MEMBER)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Site {
  id           String    @id @default(cuid())
  companyId    String
  name         String
  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  country      String?   @db.VarChar(2)
  postalCode   String?
  createdById  String?
  updatedById  String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy          User?              @relation("SiteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?              @relation("SiteUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  wasteFlows         WasteFlow[]
  fuelEntries        FuelEntry[]
  electricityEntries ElectricityEntry[]
  scope3Entries      Scope3Entry[]
  documents          Document[]

  @@index([companyId])
  @@index([deletedAt])
}

// ─── Carbon accounting (Scope 1 / 2 / Waste) ─────────────────────

model EmissionFactor {
  id            String           @id @default(cuid())
  category      EmissionCategory
  subtype       String // "diesel", "petrol_gasoline", "grid_electricity_pt", "landfill_plastic", ...
  unit          String // "L", "m3", "kWh", "kg", "ton"
  kgCo2ePerUnit Decimal          @db.Decimal(14, 6)
  source        String // e.g. "DEFRA 2024"
  region        String?          @db.VarChar(16) // "PT", "EU", "GLOBAL", ...
  year          Int
  notes         String?
  companyId     String? // null = global default; set = company override
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  company            Company?           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fuelEntries        FuelEntry[]
  electricityEntries ElectricityEntry[]
  scope3Entries      Scope3Entry[]

  @@unique([category, subtype, region, year, companyId])
  @@index([category, subtype])
}

enum EmissionCategory {
  FUEL
  ELECTRICITY
  WASTE_LANDFILL
  WASTE_INCINERATION
  WASTE_RECYCLING
  WASTE_COMPOSTING
  PRODUCTION
  TRANSPORT
  // Scope 3 categories — added 0007
  BUSINESS_TRAVEL
  EMPLOYEE_COMMUTING
  PURCHASED_GOODS
  OTHER
}

/// Scope 3 GHG Protocol categories per Spec §12.3. We ship the 7 most
/// material categories for industrial / manufacturing tenants in MVP;
/// the remaining 8 (categories 8–15) can land later without schema
/// changes since `categoryData` is JSONB.
enum Scope3Category {
  PURCHASED_GOODS_SERVICES   // Cat 1
  FUEL_ENERGY_RELATED        // Cat 3
  UPSTREAM_TRANSPORT         // Cat 4
  WASTE_GENERATED            // Cat 5
  BUSINESS_TRAVEL            // Cat 6
  EMPLOYEE_COMMUTING         // Cat 7
  DOWNSTREAM_TRANSPORT       // Cat 9
}

model FuelEntry {
  id                 String              @id @default(cuid())
  companyId          String
  siteId             String?
  fuelType           String // matches EmissionFactor.subtype: "diesel", "petrol", "natural_gas", ...
  emissionSourceType EmissionSourceType? // Spec §10.4: stationary, mobile, boiler, generator…
  quantity           Decimal             @db.Decimal(14, 3)
  unit               String // "L", "m3", "kg", "kWh"
  month              DateTime // first day of the accounting month (UTC)
  reportingYear      Int? // denormalised for fast YoY queries (derived from month)
  reportingMonth     Int? // 1–12 (derived from month)
  locationName       String?
  emissionFactorId   String?
  factorSnapshot     Json? // frozen factor metadata at write-time: {value, unit, source, region, year, version, type}
  kgCo2e             Decimal?            @db.Decimal(14, 3) // snapshot at time of write
  notes              String?
  recordStatus       RecordStatus        @default(ACTIVE)
  createdById        String?
  updatedById        String?
  deletedAt          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site           Site?           @relation(fields: [siteId], references: [id], onDelete: SetNull)
  emissionFactor EmissionFactor? @relation(fields: [emissionFactorId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("FuelEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?           @relation("FuelEntryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([companyId, month])
  @@index([companyId, reportingYear])
  @@index([companyId, reportingYear, reportingMonth])
  @@index([siteId])
  @@index([recordStatus])
  @@index([deletedAt])
}

model ElectricityEntry {
  id                  String       @id @default(cuid())
  companyId           String
  siteId              String?
  kwh                 Decimal      @db.Decimal(14, 3)
  month               DateTime
  reportingYear       Int? // denormalised for fast YoY queries
  reportingMonth      Int? // 1–12
  renewablePercent    Decimal?     @db.Decimal(5, 2) // 0.00–100.00
  energyProvider      String?
  locationName        String?
  emissionFactorId    String?
  factorSnapshot      Json? // frozen location-based factor metadata at write-time
  // Dual GHG-Protocol calculation (Spec §11.4, Amendment A4).
  // location = kwh × grid_factor (ignores renewable% — pure grid mix).
  // market   = supplier-specific if known, else grid with renewable%
  //            discount applied to reflect contractual RECs/GoOs.
  locationBasedKgCo2e Decimal?     @db.Decimal(14, 3)
  marketBasedKgCo2e   Decimal?     @db.Decimal(14, 3)
  // Legacy single-value column. Mirrors marketBasedKgCo2e for rows written
  // after this migration; preserved unchanged on rows written before.
  // New read paths should prefer location/market explicitly.
  kgCo2e              Decimal?     @db.Decimal(14, 3)
  notes               String?
  recordStatus        RecordStatus @default(ACTIVE)
  createdById         String?
  updatedById         String?
  deletedAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site           Site?           @relation(fields: [siteId], references: [id], onDelete: SetNull)
  emissionFactor EmissionFactor? @relation(fields: [emissionFactorId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("ElectricityEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?           @relation("ElectricityEntryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([companyId, month])
  @@index([companyId, reportingYear])
  @@index([companyId, reportingYear, reportingMonth])
  @@index([siteId])
  @@index([recordStatus])
  @@index([deletedAt])
}

/// Scope 3 (value-chain) emissions entry. Polymorphic by `category`:
/// the shared core columns capture identity + period + total kgCO₂e,
/// while `categoryData` (JSONB) holds per-category fields validated
/// server-side by a Zod schema specific to that category. JSONB lets
/// us add/evolve categories without a schema migration each time.
model Scope3Entry {
  id          String         @id @default(cuid())
  companyId   String
  siteId      String?
  category    Scope3Category
  description String         // human label, e.g. "Q1 supplier deliveries"

  // Polymorphic per-category payload. See lib/schemas/scope3.schema.ts for
  // the Zod-validated shape per category.
  categoryData Json

  // Period (Spec §11.7 + Amendment A7 — denormalised for fast YoY queries).
  month          DateTime
  reportingYear  Int
  reportingMonth Int

  // Computed values
  emissionFactorId String?
  factorSnapshot   Json? // frozen factor metadata at write time (ADR-008)
  kgCo2e           Decimal? @db.Decimal(14, 3)

  notes        String?
  recordStatus RecordStatus @default(ACTIVE)

  createdById String?
  updatedById String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site           Site?           @relation(fields: [siteId], references: [id], onDelete: SetNull)
  emissionFactor EmissionFactor? @relation(fields: [emissionFactorId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("Scope3EntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?           @relation("Scope3EntryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([companyId, month])
  @@index([companyId, reportingYear])
  @@index([companyId, category])
  @@index([siteId])
  @@index([recordStatus])
  @@index([deletedAt])
}

// ─── LoW / EWC Reference Catalog (seeded, read-only) ─────────────

model WasteCode {
  code           String  @id // "150101" — stable key, no spaces
  displayCode    String // "15 01 01" — human format
  description    String
  chapterCode    String  @db.VarChar(2) // "15"
  subChapterCode String  @db.VarChar(4) // "1501"
  isHazardous    Boolean @default(false) // * marker in LoW
  isMirrorEntry  Boolean @default(false) // haz/non-haz twin
  catalogVersion String // "2014/955/EU"

  wasteFlows WasteFlow[]

  @@index([chapterCode])
  @@index([subChapterCode])
  @@index([isHazardous])
}

// Material-type groupings (UI filter layer above LoW codes)
model WasteCategory {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  sortOrder   Int     @default(0)

  wasteFlows WasteFlow[]
}

// ─── Core: WasteFlow ─────────────────────────────────────────────

model WasteFlow {
  id          String  @id @default(cuid())
  companyId   String
  siteId      String?
  categoryId  String?
  wasteCodeId String?

  // General Information
  name                String
  description         String?
  materialComposition String?
  status              WasteFlowStatus @default(ACTIVE)

  // Quantities & Frequency
  estimatedQuantity Decimal?     @db.Decimal(14, 3)
  quantityUnit      QuantityUnit @default(TON)
  frequency         Frequency    @default(MONTHLY)

  // Operations
  storageMethod      String?
  currentDestination String?
  currentOperator    String?
  locationName       String?
  internalCode       String?
  treatmentCode      TreatmentCode?
  treatmentNotes     String?

  // Additional
  recoveryNotes String?
  notes         String?
  isHazardous   Boolean @default(false)
  isPriority    Boolean @default(false)

  reportingYear  Int? // denormalised for fast YoY queries
  reportingMonth Int? // 1–12
  deletedAt      DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site      Site?          @relation(fields: [siteId], references: [id], onDelete: SetNull)
  category  WasteCategory? @relation(fields: [categoryId], references: [id])
  wasteCode WasteCode?     @relation(fields: [wasteCodeId], references: [code])
  createdBy User?          @relation("WasteFlowCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?          @relation("WasteFlowUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([companyId, reportingYear])
  @@index([siteId])
  @@index([categoryId])
  @@index([wasteCodeId])
  @@index([isHazardous])
  @@index([isPriority])
  @@index([createdAt])
  @@index([deletedAt])
}

enum WasteFlowStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum QuantityUnit {
  KG
  TON
  LITER
  CUBIC_METER
  UNIT
  PIECE
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_OFF
  CONTINUOUS
}

enum TreatmentCode {
  R1
  R2
  R3
  R4
  R5
  R6
  R7
  R8
  R9
  R10
  R11
  R12
  R13
  D1
  D2
  D3
  D4
  D5
  D6
  D7
  D8
  D9
  D10
  D11
  D12
  D13
  D14
  D15
}

// ─── Audit Trail ─────────────────────────────────────────────────

/// Company-scoped audit log of user and system actions.
/// Written synchronously from every server action via logActivity() helper.
/// Retention: 7 years for GDPR-compatible audit baseline.
model ActivityLog {
  id           String       @id @default(cuid())
  companyId    String
  userId       String? // nullable for system events (cron, data imports, etc.)
  activityType ActivityType
  module       String // "waste-flows", "scope-1", "scope-2", "documentation", "regulations", ...
  recordId     String? // nullable for non-record events (login, logout)
  description  String // human-readable summary shown in UI
  metadata     Json? // structured diff, old/new values, related IDs
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime     @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, module, recordId])
  @@index([companyId, userId, createdAt])
  @@index([activityType])
}

enum ActivityType {
  RECORD_CREATED
  RECORD_UPDATED
  RECORD_DELETED
  RECORD_STATUS_CHANGED
  DOCUMENT_UPLOADED
  DOCUMENT_DOWNLOADED
  DOCUMENT_DELETED
  TASK_CREATED
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  USER_INVITED
  USER_INVITATION_REVOKED
  USER_ROLE_CHANGED
  USER_REMOVED
  USER_LOGIN
  USER_LOGOUT
  USER_PASSWORD_CHANGED
  REGULATION_UPDATED
  EMISSION_FACTOR_IMPORTED
  IMPERSONATION_STARTED
  IMPERSONATION_ENDED
  COMPANY_CREATED
  COMPANY_UPDATED
  RECORD_EXPORTED
}

// ─── Factor Versioning (ADR-008) ─────────────────────────────────

/// Each import of a factor source (DEFRA 2025, EPA WARM v16, ...) creates
/// one FactorRevision, which associates all EmissionFactor rows created in
/// that import. Records snapshot the factor at write time (FuelEntry.factorSnapshot)
/// so historical traceability is preserved even if factors are superseded.
model FactorRevision {
  id           String   @id @default(cuid())
  companyId    String? // null = platform-wide import; set = company-specific override
  source       String // "DEFRA", "EPA WARM", "EEA", ...
  version      String // "2024", "v15", "2025-Q1", ...
  factorCount  Int      @default(0)
  importedById String?
  notes        String?
  importedAt   DateTime @default(now())

  company    Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  importedBy User?    @relation("FactorRevisionImporter", fields: [importedById], references: [id], onDelete: SetNull)

  @@unique([companyId, source, version])
  @@index([source, version])
}

// ─── Record lifecycle ────────────────────────────────────────────

enum RecordStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

/// Scope 1 emission source classification per Spec §10.4.
/// Independent from fuelType: the same fuel can be burned in different
/// source contexts (e.g. diesel in a generator vs. in a delivery truck).
enum EmissionSourceType {
  STATIONARY_COMBUSTION
  MOBILE_COMBUSTION
  COMPANY_VEHICLES
  BOILERS
  GENERATORS
  NATURAL_GAS_USE
  DIESEL_USE
  LPG_USE
  GASOLINE_USE
  PROCESS_EMISSIONS
  FUGITIVE_EMISSIONS
}

// ─── Documentation (Spec §15) ────────────────────────────────────

/// Central repository of uploaded files. Metadata lives here; bytes live
/// in object storage via lib/storage (ADR-001). Each Document can be
/// attached to many records across modules via DocumentLink (ADR-006).
model Document {
  id           String  @id @default(cuid())
  companyId    String
  uploadedById String?
  plantId      String?

  // File metadata — mirrors what lib/storage returns after upload.
  filename         String // sanitised filename as persisted
  originalFilename String // what the user uploaded as
  mimeType         String
  size             Int // bytes
  storageKey       String // opaque pointer returned by StorageBackend.upload

  // Classification & context
  documentType   DocumentType @default(OTHER)
  title          String? // user-editable; falls back to originalFilename
  description    String?
  tags           String[]     @default([])
  department     String?
  reportingYear  Int?
  reportingMonth Int?

  // Simple versioning (Spec §15.14: "keep simple for MVP").
  version Int @default(1)

  recordStatus RecordStatus @default(ACTIVE)
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy User?          @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  plant      Site?          @relation(fields: [plantId], references: [id], onDelete: SetNull)
  links      DocumentLink[]

  @@index([companyId, createdAt])
  @@index([companyId, documentType])
  @@index([companyId, reportingYear])
  @@index([companyId, plantId])
  @@index([recordStatus])
  @@index([deletedAt])
  @@index([storageKey])
}

/// Polymorphic join table — one document can back many records across
/// different modules (ADR-006). Example: a single "electricity bill PDF"
/// attached to a Scope 2 entry AND a Production Intensity record AND a
/// Regulation (as evidence of compliance).
model DocumentLink {
  id         String   @id @default(cuid())
  documentId String
  module     String // "waste-flows" | "scope-1" | "scope-2" | "scope-3" | "production" | "regulation" | "account"
  recordId   String
  linkedById String?
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  linkedBy User?    @relation("DocumentLinkLinkedBy", fields: [linkedById], references: [id], onDelete: SetNull)

  @@unique([documentId, module, recordId])
  @@index([module, recordId])
  @@index([documentId])
}

enum DocumentType {
  INVOICE
  WASTE_CERTIFICATE
  COLLECTION_RECEIPT
  FUEL_BILL
  ELECTRICITY_BILL
  SUPPLIER_DOCUMENT
  INTERNAL_REPORT
  AUDIT_EVIDENCE
  ENVIRONMENTAL_LICENSE
  CONTRACT
  EMISSIONS_EVIDENCE
  PRODUCTION_REPORT
  REGULATORY_FILE
  OTHER
}
